{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/inject.js\" UserPromptSubmit",
            "timeout": 5,
            "statusMessage": "Applying Truth Seeker..."
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/inject.js\" SubagentStart",
            "timeout": 5,
            "statusMessage": "Loading Truth Seeker..."
          }
        ]
      }
    ]
  }
}
