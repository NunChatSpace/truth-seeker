    "distractorOutputPattern": "history/rollout-version-",
    "distractorPathPattern": "history/rollout-version-[0-9]+\\.txt",
    "broadSearchCommandPatterns": ["\\brg\\b[^\\n]*(?:\\s|[\"'])(?:\\.|\\./)(?:\\s|[\"']|$)", "\\bfind\\s+(?:\\.|\\./)(?:\\s|$)"],
    "distractorFailureAt": 300,
    "falsifierOutputPatterns": ["readFileSync\\(['\"]runtime/config/version\\.txt"],
    "falsifierCommandPatterns": ["\\bsed\\b[^\\n]*runtime/app\\.js", "\\bsed\\b[^\\n]*runtime/version-source\\.js"],
    "deadHypothesisCommandPatterns": ["deployment/release\\.json", "history/"],
    "postFalsificationObjectives": [
      { "id": "replacement-evidence", "type": "replace", "commandPatterns": ["runtime/config/version\\.txt"], "maxUses": 1 },
      { "id": "behavioral-verification", "type": "verify", "commandPatterns": ["node\\s+runtime/app\\.js"], "maxUses": 1 }
    ],
    "evidenceOutputPatterns": ["runtime/config/version\\.txt", "2\\.3\\.0", "2\\.4\\.0"],
    "efficientCommandBudget": 5,
    "explorationTokenBudget": 1000,
    "postChecks": []
  }
