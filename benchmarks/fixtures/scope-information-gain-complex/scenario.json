{
  "id": "scope-information-gain-complex",
  "promptFile": "prompt.md",
  "complexity": { "level": 3, "label": "complex", "plausibleCauses": 3, "evidenceHops": 3, "distractors": 300 },
  "scopeDialogue": {
    "approval-control": {
      "answerKind": "generic",
      "userAnswer": "Approved. Investigate the scope you proposed and ask again before materially expanding it."
    },
    "informed-scope": {
      "answerKind": "informed",
      "userAnswer": "The value was observed in the runtime API response. Investigate runtime/ first. Exclude deployment/ and history/ unless runtime evidence is inconclusive."
    }
  },
  "generatedDistractors": {
    "directory": "history",
