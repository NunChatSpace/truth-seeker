  },
  "oracle": {
    "expectedStatuses": ["answered", "completed"],
    "mustAsk": false,
    "mustVerify": true,
    "mustFalsify": true,
    "requiredAnswerPatterns": ["runtime/config/version\\.txt", "2\\.3\\.0", "2\\.4\\.0"],
    "forbiddenCommandPatterns": [],
