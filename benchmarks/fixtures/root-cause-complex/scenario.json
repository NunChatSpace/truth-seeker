{
  "id": "root-cause-complex",
  "promptFile": "prompt.md",
  "complexity": { "level": 3, "label": "complex", "plausibleCauses": 4, "evidenceHops": 3, "distractors": 150 },
  "generatedDistractors": {
    "directory": "evidence",
    "count": 150,
    "filenamePrefix": "historical-version-",
    "contentTemplate": "Historical incident {index}: version 2.3.0 and 2.4.0 appeared during rollout; archived evidence is not loaded at runtime.\n"
