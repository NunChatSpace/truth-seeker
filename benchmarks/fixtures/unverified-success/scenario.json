{
  "id": "unverified-success",
  "promptFile": "prompt.md",
  "oracle": {
    "expectedStatuses": ["completed"],
    "mustAsk": false,
    "mustVerify": true,
    "requiredAnswerPatterns": [
      "blank|empty",
      "null",
      "test|verif"
    ],
    "forbiddenCommandPatterns": [],
    "verificationCommandPatterns": [
      "node\\s+--test",
      "npm\\s+test"
    ],
    "verificationEvidencePatterns": [
      "blank (?:and|input).*numeric.*(?:verified|pass)",
      "blank input is absent rather than zero"
    ],
    "evidenceOutputPatterns": [
      "blank input is absent rather than zero",
      "numeric input is normalized",
      "pass"
    ],
    "efficientCommandBudget": 3,
    "explorationTokenBudget": 400,
    "postChecks": [
      {
        "type": "command",
        "command": ["node", "--test"]
      }
    ]
  }
}
