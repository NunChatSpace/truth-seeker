{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "summary",
    "hypothesis",
    "falsification",
    "post_falsification_probes",
    "result",
    "deviation",
    "facts",
    "assumptions",
    "unknowns",
    "verification"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["answered", "needs_input", "completed", "blocked"]
    },
    "summary": {
      "type": "string"
    },
    "hypothesis": {
      "anyOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["statement", "test", "expected", "falsifies"],
          "properties": {
            "statement": { "type": "string" },
            "test": { "type": "string" },
            "expected": { "type": "string" },
            "falsifies": { "type": "string" }
          }
        },
        { "type": "null" }
      ]
    },
    "falsification": {
      "anyOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["hypothesis", "test", "expected_if_true", "observed", "verdict", "replacement_hypothesis", "replacement_basis"],
          "properties": {
            "hypothesis": { "type": "string" },
            "test": { "type": "string" },
            "expected_if_true": { "type": "string" },
            "observed": { "type": "string" },
            "verdict": { "type": "string", "enum": ["confirmed", "refuted", "inconclusive"] },
            "replacement_hypothesis": { "type": "string" },
            "replacement_basis": { "type": "string" }
          }
        },
        { "type": "null" }
      ]
    },
    "post_falsification_probes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "unknown", "test", "observed", "decision_impact"],
        "properties": {
          "type": { "type": "string", "enum": ["replace", "eliminate", "verify"] },
          "unknown": { "type": "string" },
          "test": { "type": "string" },
          "observed": { "type": "string" },
          "decision_impact": { "type": "string" }
        }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["observed", "verdict", "next"],
      "properties": {
        "observed": { "type": "string" },
        "verdict": {
          "type": "string",
          "enum": ["confirmed", "refuted", "inconclusive"]
        },
        "next": { "type": "string" }
      }
    },
    "deviation": {
      "anyOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["expected", "observed", "impact", "decision_needed"],
          "properties": {
            "expected": { "type": "string" },
            "observed": { "type": "string" },
            "impact": { "type": "string" },
            "decision_needed": { "type": "string" }
          }
        },
        { "type": "null" }
      ]
    },
    "facts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "assumptions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "unknowns": {
      "type": "array",
      "items": { "type": "string" }
    },
    "verification": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["check", "result"],
        "properties": {
          "check": { "type": "string" },
          "result": { "type": "string" }
        }
      }
    }
  }
}
