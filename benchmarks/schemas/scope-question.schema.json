{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "question", "options"],
  "properties": {
    "status": { "const": "needs_input" },
    "question": { "type": "string", "minLength": 1 },
    "options": {
      "type": "array",
      "minItems": 2,
      "maxItems": 4,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
